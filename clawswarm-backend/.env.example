# === Required for live mode ===
ANTHROPIC_API_KEY=your_key
TELNYX_API_KEY=your_key
TELNYX_PHONE_NUMBER=your_number
USER_PHONE_NUMBER=your_number

# === Optional: LLM provider ===
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# OPENAI_API_KEY=your_key
# OPENAI_MODEL=gpt-4o-mini

# === Optional: Voice ===
# RESEMBLE_API_KEY=your_key
# RESEMBLE_PROJECT_ID=your_id
# RESEMBLE_VOICE_NAME=ClawSwarm Concierge

# === Optional: ClawdTalk voice calls ===
# CLAWDTALK_WS_URL=wss://your_url
# CLAWDTALK_PHONE_NUMBER=your_number
# CLAWDTALK_API_KEY=your_key
# CLAWDTALK_API_URL=https://your_url
# CLAWDTALK_SKILL_DIR=./skill

# === Optional: Server tuning ===
# PORT=8787
# CORS_ORIGIN=*
# SIMULATION_DELAY_MS=350
# AUTO_APPROVAL_DELAY_MS=3000
# MERCHANT_RESPONSE_TIMEOUT_MS=30000
